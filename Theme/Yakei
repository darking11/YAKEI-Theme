# YAKEI  夕景  —  Color Theme
# "Evening Scenery" · A warm pixel-sunset dark theme
# Sampled from a pixel-art cityscape at dusk, March 2026
# Structure inspired by Catppuccin / Everforest conventions (Also many of the Ui themes)
# ─────────────────────────────────────────────────────────────
	`#0969DA`

═══════════════════════════════════════
  BASE  —  Backgrounds & Surfaces
  (Dark mode primary layer stack)
  These are the background colors, from
  the absolute darkest to raised surfaces.
═══════════════════════════════════════

  crust        #040100   ·  Near-black. Deepest bg, statusbar, terminal bg.
  mantle       #1C140C   ·  Slightly lifted. Used behind panels/sidebars.
  base         #2A1F16   ·  Main editor/app background.
  surface-0    #352E25   ·  Cards, floating panels, popups.
  surface-1    #4A3B2E   ·  Hovered surfaces, selected rows.
  surface-2    #5C4A38   ·  Active/focused elements, borders on surfaces.
  overlay-0    #785845   ·  Subtle borders, input outlines, dividers.
  overlay-1    #9D928B   ·  Stronger borders, scrollbar tracks.


═══════════════════════════════════════
  TEXT  —  Foreground Scale
  Reads warm, not cold. All text stays
  within the amber-cream family.
═══════════════════════════════════════

  subtext-0    #A1735F  ·  Disabled text, placeholder, very muted labels.
  subtext-1    #C67F60   ·  Secondary text, captions, metadata.
  muted        #DBA078   ·  Dimmed body text, descriptions.
  text         #EBDAD7   ·  Primary readable text. Main foreground.


═══════════════════════════════════════
  ACCENTS  —  Named Colors
  The full expressive palette. All
  derived directly from the cityscape
  sunset. Each name describes its
  visual temperature/feeling.
═══════════════════════════════════════

  ember        #A95131   ·  Deep red-orange. Errors, urgent UI, warnings.
  soot         #74341E   ·  Dark rust-red. Critical errors, danger zones.
  flare        #E08534   ·  Bright saturated orange. Primary accent, cursor,
                            selection highlight, active tab indicator.
  flame        #D78157   ·  Mid orange. Secondary highlights, active icons.
  sand         #DD8B5F   ·  Warm sandy orange. Strings in syntax, badges.
  copper       #B16A49   ·  Muted copper. Borders with accent, icon strokes.
  rust         #926C5B   ·  Dusty rust. Subtle accent, inactive tab text.
  sienna       #A56C44   ·  Earthy brown-orange. Success state (warm green alt).
  peach        #E59664   ·  Soft peach. Variables, identifiers, links.
  amber        #E79759   ·  Pure amber. Keywords, reserved words.
  gold         #EAA062   ·  Warm gold. Object properties, JSON keys.
  honey        #EDAC74   ·  Lightest accent. Function names, method calls.


═══════════════════════════════════════
  LIGHT VARIANT  —  Inverted palette
  Warm parchment surface, dark ink.
  Suitable for a light mode companion.
═══════════════════════════════════════

  bg           #EBDAD7   ·  Main background (warm off-white / parchment).
  bg-alt       #DBA078   ·  Panel background (muted peach).
  surface      #E59664   ·  Raised cards (warm peach tint).
  border       #C67F60   ·  Dividers, input outlines.
  text         #040100   ·  Primary text (near-black).
  text-muted   #352E25   ·  Secondary text (dark warm brown).
  text-subtle  #785845   ·  Disabled / placeholder text.
  accent       #A95131   ·  Primary accent (ember, saturated on light bg).
  accent-alt   #74341E   ·  Darker accent for pressed/active states.


═══════════════════════════════════════
  SYNTAX HIGHLIGHT ROLES
  Editor token → Yakei color mapping.
  Works for Neovim, VS Code, Zed, etc.
═══════════════════════════════════════

  keyword          amber    #E79759   ·  if, else, return, function, local
  keyword.alt      ember    #A95131   ·  and, or, not, in (secondary keywords)
  function         honey    #EDAC74   ·  Function names, method definitions
  function.call    gold     #EAA062   ·  Function/method call sites
  variable         peach    #E59664   ·  Local variables, identifiers
  property         gold     #EAA062   ·  Object properties, struct fields
  string           sand     #DD8B5F   ·  String literals (all flavors)
  number           flame    #D78157   ·  Numeric literals
  boolean          amber    #E79759   ·  true / false / nil / null
  operator         subtext1 #C67F60   ·  = + - * / % == ~= .. and symbols
  comment          overlay1 #9D928B   ·  -- // /* */ inline & block comments
  type             honey    #EDAC74   ·  Type annotations, class names
  constant         peach    #E59664   ·  Constants, enum values
  parameter        flare    #E08534   ·  Function parameters (highlighted)
  punctuation      muted    #DBA078   ·  Brackets, commas, colons, semicolons
  macro            ember    #A95131   ·  Macros, preprocessor, decorators
  tag              amber    #E79759   ·  HTML/XML tags
  attribute        gold     #EAA062   ·  HTML attributes, JSX props
  regex            flame    #D78157   ·  Regex literals
  escape           copper   #B16A49   ·  Escape sequences within strings
  diff.add         sienna   #A56C44   ·  Added lines in diffs
  diff.delete      soot     #74341E   ·  Removed lines in diffs
  diff.change      amber    #E79759   ·  Modified lines in diffs


═══════════════════════════════════════
  UI SEMANTIC ROLES
  Application-level color assignments
  beyond just syntax.
═══════════════════════════════════════

  cursor           flare    #E08534   ·  Text cursor, caret
  selection.bg     surface2 #5C4A38   ·  Selected text background
  selection.fg     text     #EBDAD7   ·  Selected text foreground
  line.highlight   surface0 #352E25   ·  Current line highlight
  search.match     amber    #E79759   ·  Search result highlight
  search.active    flare    #E08534   ·  Active/current search match
  indent.guide     overlay0 #785845   ·  Indentation guide lines
  bracket.match    honey    #EDAC74   ·  Matched bracket highlight
  error            soot     #74341E   ·  Error underlines, error icons
  warning          ember    #A95131   ·  Warning underlines, warning icons
  info             gold     #EAA062   ·  Info messages, hints
  hint             subtext0 #A1735F   ·  Subtle hints, ghost text
  link             peach    #E59664   ·  Hyperlinks, clickable text
  tab.active       text     #EBDAD7   ·  Active tab label
  tab.inactive     subtext0 #A1735F   ·  Inactive tab labels
  statusbar.bg     crust    #040100   ·  Status bar background
  statusbar.fg     subtext1 #C67F60   ·  Status bar text
  scrollbar        overlay0 #785845   ·  Scrollbar track/thumb


